class Shape {
    double area(double lenght, double width) {
        return lenght * width;
    }
    double area(double radius) {
        return Math.PI * radius *radius;
    }
}
public class Main1 {
    public static void main(String[] args) {
        Shape s = new Shape();
        System.out.println("Area of Rectangle: " + s.area(5,4));
        System.out.println("Area of Circle: " + s.area(3));
    }
}
